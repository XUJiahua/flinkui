# =============================================================================
# Flink Job Console — example environment variables
#
# Copy to `.env` and adjust. All settings use the FKO_ prefix; nested config
# keys use underscores (e.g. cluster.s3.endpoint -> FKO_CLUSTER_S3_ENDPOINT).
# Load it however you prefer, e.g.:
#   set -a && source .env && set +a && ./bin/flinkui
# A YAML config file can also be passed with `-config path.yaml`.
# =============================================================================

# ---- HTTP server ----------------------------------------------------------
# Listen address for the API + embedded UI.
FKO_ADDR=":8080"

# ---- Behaviour / timeouts -------------------------------------------------
# FlinkDeployment name = prefix + job name (matches scripts/job.sh).
FKO_DEPLOYMENT_PREFIX="flink-sql-job-"
# Savepoint poll timeout (seconds).
FKO_SAVEPOINT_TIMEOUT_SEC="120"
# Restart "wait for JobManager pod to reach zero" timeout (seconds).
FKO_STOP_TIMEOUT_SEC="120"
# Default number of log lines to tail.
FKO_LOG_TAIL_LINES="200"
# WebSocket status push interval (seconds).
FKO_STATUS_POLL_SEC="5"

# ---- Target cluster -------------------------------------------------------
# Display name for the cluster.
FKO_CLUSTER_NAME="dev"
# Namespace that holds the FlinkDeployment resources.
FKO_CLUSTER_NAMESPACE="flink-jobs"
# Path to a kubeconfig file.
#   - out-of-cluster (local dev): set this to your kubeconfig.
#   - in-cluster (running as a Pod): LEAVE EMPTY to use the mounted ServiceAccount.
FKO_CLUSTER_KUBECONFIG="${HOME}/.kube/config"
# Optional kubeconfig context (empty = current-context).
FKO_CLUSTER_CONTEXT=""

# ---- S3 / MinIO (rollback recovery-point selector; optional) --------------
# Enables the savepoint/checkpoint listing used by rollback. The store is
# activated when an endpoint OR access key is set. Recovery-point paths are
# read from each deployment's own state.savepoints.dir / state.checkpoints.dir,
# so any bucket/prefix layout works.
#
# IMPORTANT: point this at the MinIO *S3 API* port (usually 9000), NOT the
# web console port. In-cluster this is typically the ClusterIP Service, e.g.
# https://minio.flink-operator:9000. Out-of-cluster you may need a NodePort,
# ingress, or `kubectl port-forward svc/minio 9000:9000`.
FKO_CLUSTER_S3_ENDPOINT="https://minio.flink-operator:9000"
# Optional fallback bucket (only used when a deployment does not declare its
# state dirs). Leave empty if all deployments set state.savepoints.dir.
FKO_CLUSTER_S3_BUCKET=""
FKO_CLUSTER_S3_ACCESS_KEY="minioadmin"
FKO_CLUSTER_S3_SECRET_KEY="minioadmin"
# Signing region (any value works for MinIO).
FKO_CLUSTER_S3_REGION="us-east-1"
# Path-style addressing: true for MinIO, false for AWS S3 / OSS virtual-host.
FKO_CLUSTER_S3_PATH_STYLE="true"
# Skip TLS verification — set true for internal MinIO with a self-signed cert.
FKO_CLUSTER_S3_INSECURE="true"

# ---- Authentication (REQUIRED) --------------------------------------------
# The console can mutate cluster workloads, so it must not run unauthenticated.
FKO_AUTH_USERNAME="admin"
# Set a strong password — the service refuses to be secure without it.
FKO_AUTH_PASSWORD="change-me"
# Cookie signing secret — generate a strong random value, e.g.:
#   openssl rand -hex 16
FKO_AUTH_SESSION_SECRET="change-me-please"
